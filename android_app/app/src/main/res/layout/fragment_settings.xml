<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?android:attr/colorBackground">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Analysis Settings"
            android:textAppearance="?attr/textAppearanceHeadlineSmall"
            android:layout_marginBottom="8dp" />

        <TextView
            android:id="@+id/tvUnsavedBanner"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Settings modified — unsaved changes"
            android:textAppearance="?attr/textAppearanceLabelMedium"
            android:background="?attr/colorErrorContainer"
            android:textColor="?attr/colorOnErrorContainer"
            android:padding="10dp"
            android:gravity="center"
            android:layout_marginBottom="8dp"
            android:visibility="gone" />

        <!-- ══ Section 0: Appearance ════════════════════════════════ -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:cardElevation="2dp">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="vertical" android:padding="16dp">

                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Appearance" android:textAppearance="?attr/textAppearanceTitleMedium"
                    android:layout_marginBottom="12dp"/>

                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:hint="Dark Mode"
                    style="@style/Widget.Material3.TextInputLayout.OutlinedBox.ExposedDropdownMenu">
                    <com.google.android.material.textfield.MaterialAutoCompleteTextView
                        android:id="@+id/spinnerDarkMode"
                        android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:inputType="none" android:focusable="false" />
                </com.google.android.material.textfield.TextInputLayout>

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- ══ Section 1: Channel & Gamma ═══════════════════════════ -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:cardElevation="2dp">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="vertical" android:padding="16dp">

                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="1 · Import" android:textAppearance="?attr/textAppearanceTitleMedium"
                    android:layout_marginBottom="12dp"/>

                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:hint="Channel" android:layout_marginBottom="12dp"
                    style="@style/Widget.Material3.TextInputLayout.OutlinedBox.ExposedDropdownMenu">
                    <com.google.android.material.textfield.MaterialAutoCompleteTextView
                        android:id="@+id/spinnerChannel"
                        android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:inputType="none" android:focusable="false" />
                </com.google.android.material.textfield.TextInputLayout>

                <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:text="Gamma correction" android:textAppearance="?attr/textAppearanceBodyMedium"/>
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:gravity="center_vertical">
                    <com.google.android.material.slider.Slider
                        android:id="@+id/sliderGamma"
                        android:layout_width="0dp" android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:valueFrom="0.10" android:valueTo="5.0" android:stepSize="0.05"
                        android:value="0.85" />
                    <TextView
                        android:id="@+id/tvGammaValue"
                        android:layout_width="40dp" android:layout_height="wrap_content"
                        android:text="0.85" android:gravity="center"
                        android:textAppearance="?attr/textAppearanceLabelLarge"/>
                </LinearLayout>

                <com.google.android.material.switchmaterial.SwitchMaterial
                    android:id="@+id/switchStretch"
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:text="Contrast stretch (1st–99th percentile)"
                    android:layout_marginTop="8dp"/>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- ══ Section 2: Circular Mask ═════════════════════════════ -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:cardElevation="2dp">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="vertical" android:padding="16dp">

                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="2 · Circular Mask" android:textAppearance="?attr/textAppearanceTitleMedium"
                    android:layout_marginBottom="12dp"/>

                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:hint="Mask source" android:layout_marginBottom="8dp"
                    style="@style/Widget.Material3.TextInputLayout.OutlinedBox.ExposedDropdownMenu">
                    <com.google.android.material.textfield.MaterialAutoCompleteTextView
                        android:id="@+id/spinnerMask"
                        android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:inputType="none" android:focusable="false" />
                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.switchmaterial.SwitchMaterial
                    android:id="@+id/switchCircular"
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:text="Circular fisheye (uncheck = fullframe)"
                    android:checked="true"
                    android:layout_marginBottom="8dp"/>

                <!-- Manual mask inputs -->
                <LinearLayout
                    android:id="@+id/layoutManualMask"
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:visibility="gone">

                    <com.google.android.material.textfield.TextInputLayout
                        android:layout_width="0dp" android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:hint="xc (px)" android:layout_marginEnd="4dp"
                        style="@style/Widget.Material3.TextInputLayout.OutlinedBox">
                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etMaskXc"
                            android:layout_width="match_parent" android:layout_height="wrap_content"
                            android:inputType="number" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <com.google.android.material.textfield.TextInputLayout
                        android:layout_width="0dp" android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:hint="yc (px)" android:layout_marginHorizontal="4dp"
                        style="@style/Widget.Material3.TextInputLayout.OutlinedBox">
                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etMaskYc"
                            android:layout_width="match_parent" android:layout_height="wrap_content"
                            android:inputType="number" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <com.google.android.material.textfield.TextInputLayout
                        android:layout_width="0dp" android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:hint="rc (px)" android:layout_marginStart="4dp"
                        style="@style/Widget.Material3.TextInputLayout.OutlinedBox">
                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etMaskRc"
                            android:layout_width="match_parent" android:layout_height="wrap_content"
                            android:inputType="number" />
                    </com.google.android.material.textfield.TextInputLayout>
                </LinearLayout>

                <!-- Camera preset dropdown -->
                <LinearLayout
                    android:id="@+id/layoutCameraPreset"
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:visibility="gone"
                    android:layout_marginTop="4dp">

                    <com.google.android.material.textfield.TextInputLayout
                        android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:hint="Camera model"
                        style="@style/Widget.Material3.TextInputLayout.OutlinedBox.ExposedDropdownMenu">
                        <com.google.android.material.textfield.MaterialAutoCompleteTextView
                            android:id="@+id/spinnerCameraPreset"
                            android:layout_width="match_parent" android:layout_height="wrap_content"
                            android:inputType="none" android:focusable="false" />
                    </com.google.android.material.textfield.TextInputLayout>

                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- ══ Section 3: Binarization ══════════════════════════════ -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:cardElevation="2dp">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="vertical" android:padding="16dp">

                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="3 · Binarization" android:textAppearance="?attr/textAppearanceTitleMedium"
                    android:layout_marginBottom="12dp"/>

                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:hint="Threshold method" android:layout_marginBottom="8dp"
                    style="@style/Widget.Material3.TextInputLayout.OutlinedBox.ExposedDropdownMenu">
                    <com.google.android.material.textfield.MaterialAutoCompleteTextView
                        android:id="@+id/spinnerThreshold"
                        android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:inputType="none" android:focusable="false" />
                </com.google.android.material.textfield.TextInputLayout>

                <LinearLayout
                    android:id="@+id/layoutManualThreshold"
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:visibility="gone">
                    <com.google.android.material.textfield.TextInputLayout
                        android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:hint="Manual threshold (0–255)"
                        style="@style/Widget.Material3.TextInputLayout.OutlinedBox">
                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etManualThreshold"
                            android:layout_width="match_parent" android:layout_height="wrap_content"
                            android:inputType="number" android:text="128" />
                    </com.google.android.material.textfield.TextInputLayout>
                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- ══ Section 4: Gap Fraction ═══════════════════════════════ -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:cardElevation="2dp">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="vertical" android:padding="16dp">

                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="4 · Gap Fraction" android:textAppearance="?attr/textAppearanceTitleMedium"
                    android:layout_marginBottom="12dp"/>

                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:hint="Lens type" android:layout_marginBottom="12dp"
                    style="@style/Widget.Material3.TextInputLayout.OutlinedBox.ExposedDropdownMenu">
                    <com.google.android.material.textfield.MaterialAutoCompleteTextView
                        android:id="@+id/spinnerLens"
                        android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:inputType="none" android:focusable="false" />
                </com.google.android.material.textfield.TextInputLayout>

                <!-- VZA range inputs -->
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:layout_marginBottom="12dp">
                    <com.google.android.material.textfield.TextInputLayout
                        android:layout_width="0dp" android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:hint="Max VZA (°)" android:layout_marginEnd="4dp"
                        style="@style/Widget.Material3.TextInputLayout.OutlinedBox">
                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etMaxVza"
                            android:layout_width="match_parent" android:layout_height="wrap_content"
                            android:inputType="numberDecimal" android:text="90" />
                    </com.google.android.material.textfield.TextInputLayout>
                    <com.google.android.material.textfield.TextInputLayout
                        android:layout_width="0dp" android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:hint="Start VZA (°)" android:layout_marginHorizontal="4dp"
                        style="@style/Widget.Material3.TextInputLayout.OutlinedBox">
                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etStartVza"
                            android:layout_width="match_parent" android:layout_height="wrap_content"
                            android:inputType="numberDecimal" android:text="0" />
                    </com.google.android.material.textfield.TextInputLayout>
                    <com.google.android.material.textfield.TextInputLayout
                        android:layout_width="0dp" android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:hint="End VZA (°)" android:layout_marginStart="4dp"
                        style="@style/Widget.Material3.TextInputLayout.OutlinedBox">
                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etEndVza"
                            android:layout_width="match_parent" android:layout_height="wrap_content"
                            android:inputType="numberDecimal" android:text="70" />
                    </com.google.android.material.textfield.TextInputLayout>
                </LinearLayout>

                <!-- Rings slider -->
                <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:text="Zenith rings" android:textAppearance="?attr/textAppearanceBodyMedium"/>
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:gravity="center_vertical">
                    <com.google.android.material.slider.Slider
                        android:id="@+id/sliderRings"
                        android:layout_width="0dp" android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:valueFrom="1" android:valueTo="20" android:stepSize="1"
                        android:value="7" />
                    <TextView android:id="@+id/tvRingsValue"
                        android:layout_width="30dp" android:layout_height="wrap_content"
                        android:text="7" android:gravity="center"
                        android:textAppearance="?attr/textAppearanceLabelLarge"/>
                </LinearLayout>

                <!-- Segments slider -->
                <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:text="Azimuth segments" android:textAppearance="?attr/textAppearanceBodyMedium"
                    android:layout_marginTop="8dp"/>
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:gravity="center_vertical">
                    <com.google.android.material.slider.Slider
                        android:id="@+id/sliderSegments"
                        android:layout_width="0dp" android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:valueFrom="1" android:valueTo="36" android:stepSize="1"
                        android:value="8" />
                    <TextView android:id="@+id/tvSegmentsValue"
                        android:layout_width="30dp" android:layout_height="wrap_content"
                        android:text="8" android:gravity="center"
                        android:textAppearance="?attr/textAppearanceLabelLarge"/>
                </LinearLayout>

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- ══ Action Buttons ═══════════════════════════════════════ -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:layout_marginTop="8dp">
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnResetDefaults"
                android:layout_width="0dp" android:layout_weight="1"
                android:layout_height="wrap_content"
                android:layout_marginEnd="4dp"
                android:text="Reset Defaults"
                style="@style/Widget.Material3.Button.TextButton" />
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnCancel"
                android:layout_width="0dp" android:layout_weight="1"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="4dp"
                android:text="Cancel"
                style="@style/Widget.Material3.Button.OutlinedButton" />
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnSaveSettings"
                android:layout_width="0dp" android:layout_weight="1"
                android:layout_height="wrap_content"
                android:layout_marginStart="4dp"
                android:text="Save"
                style="@style/Widget.Material3.Button" />
        </LinearLayout>

    </LinearLayout>
</ScrollView>
